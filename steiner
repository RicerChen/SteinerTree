<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>直角平面最小 Steiner 树 · 计算与演示</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&family=Noto+Sans+SC:wght@300;400;500&display=swap');

:root {
/* Claude API Docs palette */
--bg:       #f5f2ec;   /* warm cream page bg */
--panel:    #ffffff;   /* sidebar / header */
--panel2:   #f9f7f3;   /* card / input bg */
--border:   #e4dfd6;   /* subtle warm gray */
--border2:  #d4cdc3;   /* slightly stronger */

```
/* Anthropic brand orange + supporting tones */
--accent:   #c96a2e;   /* primary orange (logo, links, highlights) */
--accent-h: #a8531f;   /* hover darken */
--accent-l: #f5ece4;   /* light tint for active states */

/* Algorithm visualization colours — warm & accessible on cream */
--rmst-col: #8a9bb0;   /* muted steel-blue   — RMST baseline */
--approx-col:#2e9e5e;  /* forest green       — 2-approx */
--steiner:  #7c4db8;   /* violet             — Steiner points */
--terminal: #c96a2e;   /* orange = accent    — terminal pts */
--anim-hl:  #c96a2e;   /* orange highlight in animation */

/* Text */
--text:     #1a1714;   /* near-black body */
--text2:    #3d3530;   /* secondary text */
--dim:      #7a6f67;   /* tertiary / labels */
--muted:    #b0a49a;   /* placeholder / disabled */
```

}

- {margin:0;padding:0;box-sizing:border-box;}

body{
font-family:'Inter','Noto Sans SC',sans-serif;
background:var(--bg);color:var(--text);
height:100vh;display:flex;flex-direction:column;overflow:hidden;
font-size:13px;line-height:1.5;
}

/* ── Header ─────────────────────────────────── */
header{
display:flex;align-items:center;justify-content:space-between;
padding:11px 22px;
background:var(--panel);
border-bottom:1px solid var(--border);
flex-shrink:0;
box-shadow:0 1px 3px rgba(0,0,0,.04);
}
.htitle{display:flex;align-items:baseline;gap:12px;}
.htitle h1{
font-family:'Lora',serif;
font-size:16px;font-weight:500;
color:var(--text);letter-spacing:-.01em;
}
.htitle .sub{
font-family:'JetBrains Mono',monospace;
font-size:10px;color:var(--accent);
letter-spacing:.07em;text-transform:uppercase;
font-weight:400;
}
.hmeta{
font-family:'JetBrains Mono',monospace;
font-size:11px;color:var(--dim);
display:flex;gap:16px;align-items:center;
}
.sdot{
display:inline-block;width:6px;height:6px;
border-radius:50%;background:var(--approx-col);
margin-right:5px;animation:pulse 2.5s infinite;
}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.25;}}

/* ── Layout ─────────────────────────────────── */
.main{display:flex;flex:1;overflow:hidden;}

/* ── Sidebar ─────────────────────────────────── */
.sidebar{
width:272px;background:var(--panel);
border-right:1px solid var(--border);
display:flex;flex-direction:column;
overflow-y:auto;flex-shrink:0;
}
.sec{padding:14px;border-bottom:1px solid var(--border);}
.stitle{
font-family:'JetBrains Mono',monospace;
font-size:9px;text-transform:uppercase;
letter-spacing:.14em;color:var(--muted);
margin-bottom:10px;font-weight:500;
}

/* ── Buttons ─────────────────────────────────── */
.btn{
width:100%;padding:8px 11px;
border:1px solid var(--border);
background:var(--panel2);color:var(--text2);
font-family:'Inter','Noto Sans SC',sans-serif;
font-size:12px;font-weight:400;
cursor:pointer;border-radius:6px;
margin-bottom:5px;transition:all .14s;
display:flex;align-items:center;gap:7px;text-align:left;
}
.btn:hover{
border-color:var(--accent);color:var(--accent);
background:var(--accent-l);
}
.btn:active{transform:scale(.985);}

.btn.dng{color:#c53030;border-color:#f0d5d5;}
.btn.dng:hover{border-color:#c53030;background:#fdf0f0;color:#c53030;}

.btn.exp{color:#7c5a1e;border-color:#e8d8b8;}
.btn.exp:hover{border-color:#c96a2e;background:var(--accent-l);color:var(--accent);}

.bi{
width:16px;height:16px;border-radius:4px;
display:flex;align-items:center;justify-content:center;
font-size:9px;flex-shrink:0;
}
.btn-rmst .bi{background:#e8eef6;color:#8a9bb0;}
.btn-approx .bi{background:var(--accent-l);color:var(--accent);}

/* ── Param rows ─────────────────────────────── */
.prow{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.plabel{font-size:12px;color:var(--dim);}
.pinput{display:flex;align-items:center;gap:5px;}
.pinput button{
width:22px;height:22px;
background:var(--panel2);border:1px solid var(--border2);
color:var(--dim);cursor:pointer;border-radius:4px;
font-size:14px;display:flex;align-items:center;justify-content:center;
transition:all .14s;
}
.pinput button:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-l);}
.pval{
font-family:'JetBrains Mono',monospace;
font-size:14px;color:var(--accent);
font-weight:600;width:26px;text-align:center;
}

/* ── Speed slider ─────────────────────────────── */
.srow{display:flex;align-items:center;gap:8px;margin-bottom:7px;}
.slabel{font-size:11px;color:var(--dim);flex-shrink:0;width:56px;}
.sslider{
flex:1;-webkit-appearance:none;height:3px;
background:var(--border2);border-radius:2px;outline:none;
}
.sslider::-webkit-slider-thumb{
-webkit-appearance:none;width:12px;height:12px;
border-radius:50%;background:var(--accent);cursor:pointer;
box-shadow:0 1px 3px rgba(0,0,0,.15);
}
.slval{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--accent);width:26px;text-align:right;}

/* ── Anim controls ─────────────────────────── */
.actrls{display:flex;gap:4px;margin-top:7px;}
.abtn{
flex:1;padding:5px;
border:1px solid var(--border);
background:var(--panel2);color:var(--dim);
font-family:'JetBrains Mono',monospace;font-size:10px;
cursor:pointer;border-radius:4px;
transition:all .14s;display:flex;align-items:center;justify-content:center;gap:3px;
}
.abtn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-l);}
.abtn:disabled{opacity:.35;cursor:default;}
.apwrap{
background:var(--panel2);border:1px solid var(--border);
border-radius:10px;overflow:hidden;height:4px;margin-top:7px;
}
.apbar{height:100%;background:var(--accent);transition:width .12s;width:0%;border-radius:10px;}
.sinfo{
font-family:'JetBrains Mono',monospace;font-size:10px;
color:var(--dim);margin-top:5px;line-height:1.55;min-height:30px;
}

/* ── Legend ─────────────────────────────────── */
.li{display:flex;align-items:center;gap:7px;font-size:11px;color:var(--dim);margin-bottom:5px;}
.ldot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.lline{width:18px;height:2px;flex-shrink:0;border-radius:1px;}

/* ── Comparison table ────────────────────────── */
.ctbl{width:100%;border-collapse:collapse;font-size:11px;}
.ctbl th{
font-family:'JetBrains Mono',monospace;font-size:9px;
text-transform:uppercase;letter-spacing:.07em;
color:var(--muted);padding:4px 5px;text-align:left;
border-bottom:1px solid var(--border);
}
.ctbl td{
padding:5px 5px;
border-bottom:1px solid var(--border);
font-family:'JetBrains Mono',monospace;font-size:10px;
color:var(--dim);
}
.ctbl tr:last-child td{border-bottom:none;}
.cv{color:var(--text)!important;font-weight:600;}
.cbest{color:var(--approx-col)!important;font-weight:700;}
.cdiff{font-size:9px;color:var(--approx-col);}

/* ── Result cards ────────────────────────────── */
.rcard{
background:var(--panel2);border:1px solid var(--border);
border-radius:7px;padding:10px;margin-bottom:6px;
display:none;animation:fin .22s ease;
box-shadow:0 1px 3px rgba(0,0,0,.04);
}
.rcard.active{display:block;}
@keyframes fin{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:translateY(0);}}
.rlabel{
font-family:'JetBrains Mono',monospace;font-size:9px;
color:var(--muted);text-transform:uppercase;
letter-spacing:.1em;margin-bottom:4px;
}
.rval{
font-family:'JetBrains Mono',monospace;
font-size:20px;font-weight:600;line-height:1;margin-bottom:3px;
}
.rsub{font-size:10px;color:var(--dim);}

/* ── Canvas area ─────────────────────────────── */
.carea{flex:1;display:flex;flex-direction:column;position:relative;overflow:hidden;}
.ctbar{
display:flex;align-items:center;gap:10px;
padding:8px 14px;background:var(--panel);
border-bottom:1px solid var(--border);flex-shrink:0;
}
.chint{font-size:10px;color:var(--muted);font-family:'JetBrains Mono',monospace;}
.tbtn{
padding:3px 9px;border:1px solid var(--border);
background:transparent;color:var(--dim);
font-family:'JetBrains Mono',monospace;font-size:10px;
cursor:pointer;border-radius:4px;transition:all .14s;
}
.tbtn:hover,.tbtn.active{
border-color:var(--accent);color:var(--accent);
background:var(--accent-l);
}
canvas{flex:1;cursor:crosshair;display:block;}

/* ── Stats bar ─────────────────────────────── */
.sbar{display:flex;background:var(--panel);border-top:1px solid var(--border);flex-shrink:0;}
.si{flex:1;padding:6px 12px;border-right:1px solid var(--border);}
.si:last-child{border-right:none;}
.si .sil{
font-family:'JetBrains Mono',monospace;font-size:8px;
text-transform:uppercase;letter-spacing:.1em;
color:var(--muted);margin-bottom:2px;
}
.si .siv{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;color:var(--text);}

/* ── Right log panel ─────────────────────────── */
.rpanel{
width:220px;background:var(--panel);
border-left:1px solid var(--border);
display:flex;flex-direction:column;overflow-y:auto;flex-shrink:0;
}
.lentry{
padding:7px 13px;border-bottom:1px solid var(--border);
font-size:10px;font-family:'JetBrains Mono',monospace;
color:var(--dim);line-height:1.5;animation:fin .2s ease;
}
.ltime{color:var(--muted);font-size:9px;}
.lmsg{color:var(--text2);}
.lval{color:var(--accent);font-weight:500;}
.pchip{
display:inline-flex;align-items:center;gap:3px;
background:var(--panel2);border:1px solid var(--border);
border-radius:4px;padding:2px 6px;
font-family:'JetBrains Mono',monospace;font-size:9px;
color:var(--dim);margin:2px;cursor:pointer;transition:all .14s;
}
.pchip:hover{border-color:#c53030;color:#c53030;background:#fdf0f0;}

/* ── Notify toast ─────────────────────────────── */
.notify{
position:fixed;top:54px;left:50%;
transform:translateX(-50%) translateY(-12px);
background:var(--text);color:var(--panel);
padding:6px 16px;border-radius:20px;
font-family:'JetBrains Mono',monospace;font-size:11px;
pointer-events:none;opacity:0;transition:all .22s;z-index:100;
box-shadow:0 4px 12px rgba(0,0,0,.15);letter-spacing:.02em;
}
.notify.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* ── Mode badge ─────────────────────────────── */
.mbadge{
padding:2px 8px;border-radius:10px;
font-family:'JetBrains Mono',monospace;font-size:9px;
letter-spacing:.06em;text-transform:uppercase;
border:1px solid transparent;font-weight:500;
}
.m-none{border-color:var(--border);color:var(--muted);background:var(--panel2);}
.m-rmst{border-color:#c5d4e8;color:#8a9bb0;background:#eef3fb;}
.m-approx{border-color:#f0dcc8;color:var(--accent);background:var(--accent-l);}

.dvd{height:1px;background:var(--border);margin:5px 0;}

/* ── Export Modal ─────────────────────────────── */
.moverlay{
position:fixed;inset:0;background:rgba(26,23,20,.55);
display:flex;align-items:center;justify-content:center;
z-index:200;opacity:0;pointer-events:none;transition:opacity .2s;
backdrop-filter:blur(3px);
}
.moverlay.show{opacity:1;pointer-events:all;}
.modal{
background:var(--panel);border:1px solid var(--border);
border-radius:12px;width:590px;max-height:82vh;
display:flex;flex-direction:column;overflow:hidden;
transform:translateY(10px);transition:transform .2s;
box-shadow:0 20px 50px rgba(0,0,0,.12);
}
.moverlay.show .modal{transform:translateY(0);}
.mhdr{
display:flex;align-items:center;justify-content:space-between;
padding:14px 18px;border-bottom:1px solid var(--border);
}
.mtitle{
font-family:'Lora',serif;font-size:15px;font-weight:500;
color:var(--text);
}
.mclose{
background:none;border:none;color:var(--muted);
font-size:20px;cursor:pointer;padding:2px 5px;
border-radius:4px;line-height:1;transition:color .14s;
}
.mclose:hover{color:var(--text);}
.mbody{padding:16px 18px;overflow-y:auto;flex:1;}
.mfooter{
padding:12px 18px;border-top:1px solid var(--border);
display:flex;gap:8px;justify-content:flex-end;
background:var(--panel2);
}
.etabs{display:flex;gap:4px;margin-bottom:12px;}
.etab{
padding:5px 12px;border:1px solid var(--border);
background:var(--panel2);color:var(--dim);
font-family:'JetBrains Mono',monospace;font-size:11px;
cursor:pointer;border-radius:5px;transition:all .14s;font-weight:400;
}
.etab.active{border-color:var(--accent);color:var(--accent);background:var(--accent-l);font-weight:500;}
.econt{display:none;}.econt.active{display:block;}
.codeblk{
background:#faf8f5;border:1px solid var(--border);
border-radius:7px;padding:12px;
font-family:'JetBrains Mono',monospace;font-size:11px;
color:var(--text2);white-space:pre;overflow-x:auto;
line-height:1.65;max-height:280px;overflow-y:auto;
}
.dlbtn{
padding:7px 18px;border:1px solid var(--accent);
background:var(--accent);color:#fff;
font-family:'Inter',sans-serif;font-size:12px;font-weight:500;
cursor:pointer;border-radius:6px;transition:all .14s;
letter-spacing:.01em;
}
.dlbtn:hover{background:var(--accent-h);border-color:var(--accent-h);}

::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

/* Draw mode toggle */
.mode-toggle{
display:flex;align-items:center;
background:var(--panel2);border:1px solid var(--border);
border-radius:6px;padding:2px;gap:2px;flex-shrink:0;
}
.mtgl{
display:flex;align-items:center;gap:5px;
padding:4px 10px;border:none;background:transparent;
color:var(--dim);font-family:'JetBrains Mono',monospace;
font-size:10px;cursor:pointer;border-radius:4px;
transition:all .15s;white-space:nowrap;
}
.mtgl:hover{color:var(--text);}
.mtgl.active{
background:var(--panel);color:var(--text);
box-shadow:0 1px 3px rgba(0,0,0,.08);
}
.mtgl-dot{
width:7px;height:7px;border-radius:50%;flex-shrink:0;
}
canvas.cursor-steiner{cursor:cell;}

/* Steiner coord rows — manual variant */
.spt-row.manual .spt-id{background:#f0ebf8;color:var(--steiner);}
.spt-row.manual .spt-src{color:var(--steiner);}
.spt-row.deletable{cursor:pointer;}
.spt-row.deletable:hover .spt-coords{color:#c53030;}
.spt-row.deletable:hover .spt-id{opacity:.6;}
.spt-row{
display:flex;align-items:center;justify-content:space-between;
padding:4px 0;border-bottom:1px solid var(--border);
font-family:'JetBrains Mono',monospace;font-size:10px;
animation:fin .18s ease;
}
.spt-row:last-child{border-bottom:none;}
.spt-id{
width:28px;flex-shrink:0;
font-size:9px;font-weight:600;
padding:1px 5px;border-radius:3px;
text-align:center;
}
.spt-id.approx-id{background:var(--accent-l);color:var(--accent);}
.spt-id.manual-id{background:#f0ebf8;color:var(--steiner);}
.spt-coords{
color:var(--text2);flex:1;text-align:right;
letter-spacing:.02em;
}
.spt-src{
font-size:8px;color:var(--muted);
margin-left:6px;flex-shrink:0;
text-transform:uppercase;letter-spacing:.06em;
}
</style>
</head>
