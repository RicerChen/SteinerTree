</div>

<!-- Canvas -->
<div class="carea">
<div class="ctbar">
<!-- Draw mode toggle -->
<div class="mode-toggle" id="mode-toggle">
<button class="mtgl active" id="mode-terminal" title="点击画布放置终端点">
<span class="mtgl-dot" style="background:var(--terminal)"></span>终端点
</button>
<button class="mtgl" id="mode-steiner" title="点击画布手动放置 Steiner 点">
<span class="mtgl-dot" style="background:var(--steiner)"></span>Steiner 点
</button>
</div>
<span class="chint" id="mode-hint">点击画布添加终端点</span>
<div style="margin-left:auto;display:flex;gap:4px;align-items:center;" id="vtgls">
