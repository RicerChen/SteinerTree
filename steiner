<script>
// ==================== State ====================
const S = {
pts:[],k:5,
manualSpts:[],   // user-placed Steiner points
drawMode:'terminal', // 'terminal' | 'steiner'
rmstEdges:null,rmstLen:null,
approxEI:null,approxSpts:[],approxMax:null,approxLen:null,
showRmst:true,showApprox:true,showLabels:true,showAnim:true,
// anim
asteps:[],aidx:0,arunning:false,apaused:false,atimer:null,aspeed:900,
aei:[],ahigh:null,aspts:[],
};

// ==================== Canvas ====================
const cvs=document.getElementById('cvs'), ctx=cvs.getContext('2d');
let DPR=1;

function resize(){
const a=cvs.parentElement;
const cssW=a.clientWidth;
const cssH=a.clientHeight-a.querySelector('.ctbar').offsetHeight-document.querySelector('.sbar').offsetHeight;
DPR=window.devicePixelRatio||1;
// Set physical pixel size
cvs.width=Math.round(cssW*DPR);
cvs.height=Math.round(cssH*DPR);
// Keep CSS display size
cvs.style.width=cssW+'px';
cvs.style.height=cssH+'px';
// Scale all drawing ops to match DPR
ctx.setTransform(DPR,0,0,DPR,0,0);
draw();
}
window.addEventListener('resize',resize);
setTimeout(resize,60);

// ==================== Math ====================
function md(a,b){return Math.abs(a[0]-b[0])+Math.abs(a[1]-b[1]);}
function mst(pts){
const n=pts.length; if(n<2)return[];
const inT=new Array(n).fill(false),mn=new Array(n).fill(Infinity),par=new Array(n).fill(-1);
mn[0]=0; const edges=[];
for(let s=0;s<n;s++){
let u=-1;
for(let i=0;i<n;i++) if(!inT[i]&&(u===-1||mn[i]<mn[u]))u=i;
inT[u]=true;
if(par[u]!==-1)edges.push([par[u],u,md(pts[par[u]],pts[u])]);
for(let v=0;v<n;v++) if(!inT[v]){const d=md(pts[u],pts[v]);if(d<mn[v]){mn[v]=d;par[v]=u;}}
}
return edges;
}
function mstMaxEdge(pts){const e=mst(pts);return e.length?Math.max(...e.map(x=>x[2])):0;}

// ── Iterated 1-Steiner heuristic ─────────────────────────────────────────
function approx2(terms,k){
const me=mst(terms);
const ei=me.map(([u,v,w])=>({u,v,p1:terms[u],p2:terms[v],length:w,sc:0,cm:w}));
const steps=[];
steps.push({type:'init',ei:ei.map(e=>({...e})),high:null,msg:`初始化：RMST 共 ${ei.length} 条边，准备分配 ${k} 个 Steiner 点`});
for(let i=0;i<k;i++){
ei.sort((a,b)=>[b.cm-a.cm](http://b.cm-a.cm/));
const t=ei[0];
t.sc++;t.cm=t.length/(t.sc+1);
steps.push({type:'assign',ei:ei.map(e=>({...e})),high:{...t},step:i+1,
msg:`第 ${i+1}/${k} 步：选最长段（边 P${t.u}→P${t.v}，当前段长 ${Math.round(t.length/t.sc)}）→ 分配第 ${t.sc} 个 Steiner 点，新段长 ${Math.round(t.cm)}`});
}
const totLen=ei.reduce((s,e)=>s+e.length,0);
const maxE=Math.max(...ei.map(e=>[e.cm](http://e.cm/)));
steps.push({type:'done',ei:ei.map(e=>({...e})),high:null,msg:`完成！最长边 ${Math.round(maxE)}，总长 ${Math.round(totLen)}`});
// compute steiner positions
const spts=[];
for(const e of ei){
if([e.sc](http://e.sc/)>0){
const[x1,y1]=e.p1,[x2,y2]=e.p2,cnt=e.sc+1;
for(let j=1;j<cnt;j++){const t=j/cnt;spts.push([x1+(x2-x1)*t,y1+(y2-y1)*t]);}
}
}
return{ei,spts,len:totLen,maxE,steps};
}

function animSpts(ei){
const pts=[];
for(const e of ei){
if([e.sc](http://e.sc/)>0){
const[x1,y1]=e.p1,[x2,y2]=e.p2,cnt=e.sc+1;
for(let j=1;j<cnt;j++){const t=j/cnt;pts.push([x1+(x2-x1)*t,y1+(y2-y1)*t]);}
}
}
return pts;
}

// ==================== Drawing ====================
// Light-theme canvas palette
const C = {
bg:       '#f5f2ec',  // warm cream
grid:     'rgba(180,168,155,.35)',
rmst:     'rgba(138,155,176,.8)',
approx:   'rgba(46,158,94,.82)',
steiner:  '#7c4db8',
steinerRing:'rgba(124,77,184,.28)',
terminal: '#c96a2e',
termRing: 'rgba(201,106,46,.22)',
animHL:   '#c96a2e',
animBase: 'rgba(46,158,94,.65)',
animGlow: 'rgba(201,106,46,.25)',
textDim:  'rgba(122,111,103,.7)',
labelMain:'rgba(201,106,46,.9)',
labelSub: 'rgba(201,106,46,.45)',
};

function draw(){
// Use CSS pixel dimensions (ctx transform already scales by DPR)
const w=parseInt(cvs.style.width)||cvs.width;
const h=parseInt(cvs.style.height)||cvs.height;
// fill warm cream background
[ctx.fillStyle=C.bg](http://ctx.fillstyle=c.bg/);ctx.fillRect(0,0,w,h);
// subtle dot-grid
ctx.fillStyle=C.grid;
for(let x=40;x<w;x+=40)for(let y=40;y<h;y+=40){
ctx.beginPath();ctx.arc(x,y,.8,0,Math.PI*2);ctx.fill();
}
if(!S.pts.length){
ctx.fillStyle='rgba(176,164,154,.55)';
ctx.font='13px "JetBrains Mono",monospace';ctx.textAlign='center';
ctx.fillText('点击此处添加终端点',w/2,h/2);
ctx.font='10px "JetBrains Mono",monospace';
ctx.fillStyle='rgba(176,164,154,.35)';
ctx.fillText('Click to place terminal points',w/2,h/2+20);
return;
}
// RMST — dashed steel-blue
if(S.showRmst&&S.rmstEdges){
for(const[u,v]of S.rmstEdges)ledge(S.pts[u],S.pts[v],C.rmst,1.5,[5,4]);
}
// 2-approx final (when animation finished/not started)
if(S.showApprox&&S.approxEI&&!S.arunning&&S.aidx===0){
for(const e of S.approxEI)ledge(e.p1,e.p2,C.approx,2.5,[]);
for(const sp of S.approxSpts)dstein(sp,C.steiner,4,null);
}
// Animation layer
if(S.showAnim&&(S.arunning||S.aidx>0)&&S.aei.length){
for(const e of S.aei){
const isH=(S.ahigh&&e.u===S.ahigh.u&&e.v===S.ahigh.v);
ledge(e.p1,e.p2,isH?C.animHL:C.animBase,isH?3:2,[]);
if(isH&&[e.sc](http://e.sc/)>0){
const[x1,y1]=e.p1,[x2,y2]=e.p2,cnt=e.sc+1;
for(let j=1;j<cnt;j++){
const t=j/cnt,sx=x1+(x2-x1)t,sy=y1+(y2-y1)t;
// soft glow halo
const g=ctx.createRadialGradient(sx,sy,0,sx,sy,22);
g.addColorStop(0,C.animGlow);g.addColorStop(1,'rgba(201,106,46,0)');
ctx.fillStyle=g;ctx.beginPath();ctx.arc(sx,sy,22,0,Math.PI2);ctx.fill();
dstein([sx,sy],C.animHL,5,C.termRing);
}
}
}
for(const sp of S.aspts)dstein(sp,C.steiner,4,null);
}
// ── Manual Steiner points (user-placed) ─────────────────────────────
// Draw connecting lines first, then the dots on top
if(S.manualSpts.length){
// Build MST over terminals + manual Steiner pts and draw it
const manualAll=[...S.pts,...S.manualSpts];
const manualEdges=mst(manualAll);
for(const[u,v]of manualEdges.map(e=>[e[0],e[1]])){
ledge(manualAll[u],manualAll[v],'rgba(124,77,184,.55)',1.5,[4,3]);
}
// Draw each manual Steiner point
for(let i=0;i<S.manualSpts.length;i++){
const[x,y]=S.manualSpts[i];
// dashed outer ring — distinguishes from algo-generated pts
ctx.save();
ctx.strokeStyle=C.steiner;ctx.lineWidth=1.5;ctx.setLineDash([3,3]);
ctx.beginPath();ctx.arc(x,y,11,0,Math.PI2);ctx.stroke();
ctx.restore();
// filled core
dstein([x,y],C.steiner,5,null);
// label
if(S.showLabels){
ctx.fillStyle='rgba(124,77,184,.85)';
ctx.font='600 10px "JetBrains Mono",monospace';ctx.textAlign='center';
ctx.fillText(`M${i}`,x,y-15);
ctx.fillStyle='rgba(124,77,184,.4)';
ctx.font='9px "JetBrains Mono",monospace';
ctx.fillText(`(${Math.round(x)},${Math.round(y)})`,x,y+19);
}
}
}
// Terminal points (top layer)
for(let i=0;i<S.pts.length;i++){
const[x,y]=S.pts[i];
// soft halo
const g=ctx.createRadialGradient(x,y,0,x,y,16);
g.addColorStop(0,C.termRing);g.addColorStop(1,'rgba(201,106,46,0)');
ctx.fillStyle=g;ctx.beginPath();ctx.arc(x,y,16,0,Math.PI*2);ctx.fill();
// filled circle
ctx.fillStyle=C.terminal;ctx.beginPath();ctx.arc(x,y,5.5,0,Math.PI*2);ctx.fill();
// ring
ctx.strokeStyle='rgba(201,106,46,.5)';ctx.lineWidth=1.5;
ctx.beginPath();ctx.arc(x,y,9,0,Math.PI*2);ctx.stroke();
if(S.showLabels){
ctx.fillStyle=C.labelMain;ctx.font='600 10px "JetBrains Mono",monospace';ctx.textAlign='center';
ctx.fillText(`P${i}`,x,y-15);
ctx.fillStyle=C.labelSub;ctx.font='9px "JetBrains Mono",monospace';
ctx.fillText(`(${Math.round(x)},${Math.round(y)})`,x,y+19);
}
}
}
function ledge(p1,p2,col,lw,dash){
if(!p1||!p2)return;
ctx.strokeStyle=col;ctx.lineWidth=lw;ctx.setLineDash(dash||[]);
const[x1,y1]=p1,[x2,y2]=p2;
ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y1);ctx.lineTo(x2,y2);ctx.stroke();
ctx.setLineDash([]);
}
function dstein(pt,col,r,ringCol){
const[x,y]=pt;
ctx.fillStyle=col;ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.fill();
if(ringCol){ctx.strokeStyle=ringCol;ctx.lineWidth=1.5;ctx.beginPath();ctx.arc(x,y,r+4,0,Math.PI*2);ctx.stroke();}
}

// ==================== Animation ====================
function startAnim(steps){
S.asteps=steps;S.aidx=0;S.arunning=true;S.apaused=false;
S.aei=[];S.aspts=[];S.ahigh=null;
setAnimBtns(true);runStep();
}
function runStep(){
if(!S.arunning||S.apaused)return;
if(S.aidx>=S.asteps.length){endAnim();return;}
applyStep(S.asteps[S.aidx]);S.aidx++;
document.getElementById('apbar').style.width=(S.aidx/S.asteps.length*100)+'%';
if(S.aidx<S.asteps.length) S.atimer=setTimeout(runStep,S.aspeed);
else endAnim();
}
function applyStep(step){
S.aei=step.ei;S.ahigh=step.high||null;
if(step.type!=='init')S.aspts=animSpts(step.ei);
document.getElementById('sinfo').textContent=step.msg;
addLog(`步骤 ${S.aidx+1}`,step.msg);draw();
}
function endAnim(){
S.arunning=false;S.ahigh=null;
document.getElementById('apbar').style.width='100%';
setAnimBtns(false);
updateSteinerList(); // show final Steiner point coordinates
draw();notify('2-近似算法动画演示完成');
}
function setAnimBtns(on){
document.getElementById('apause').disabled=!on;
document.getElementById('astep').disabled=!on;
document.getElementById('areset').disabled=!on;
}

document.getElementById('apause').addEventListener('click',()=>{
if(!S.arunning)return;
S.apaused=!S.apaused;
document.getElementById('apause').textContent=S.apaused?'▶ 继续':'⏸ 暂停';
if(!S.apaused)runStep();
});
document.getElementById('astep').addEventListener('click',()=>{
if(!S.arunning)return;
S.apaused=true;clearTimeout(S.atimer);
document.getElementById('apause').textContent='▶ 继续';
if(S.aidx<S.asteps.length){applyStep(S.asteps[S.aidx]);S.aidx++;
document.getElementById('apbar').style.width=(S.aidx/S.asteps.length*100)+'%';
if(S.aidx>=S.asteps.length)endAnim();}
});
document.getElementById('areset').addEventListener('click',()=>{
clearTimeout(S.atimer);S.arunning=false;S.apaused=false;S.aidx=0;
S.aei=[];S.aspts=[];S.ahigh=null;
document.getElementById('apbar').style.width='0%';
document.getElementById('sinfo').textContent='动画已重置，可重新执行算法';
document.getElementById('apause').textContent='⏸ 暂停';
setAnimBtns(false);draw();
});

const spsl=document.getElementById('spslider'),splab=document.getElementById('splabel');
spsl.addEventListener('input',()=>{
const v=parseInt(spsl.value);
S.aspeed=Math.round(1800-v*17);
splab.textContent=['极慢','慢','中','快','极快'][Math.min(4,Math.floor(v/21))];
});

// ==================== Algorithms ====================
cvs.addEventListener('click',e=>{
const r=cvs.getBoundingClientRect();
const x=e.clientX-r.left;
const y=e.clientY-r.top;
if(S.drawMode==='steiner'){
S.manualSpts.push([x,y]);
updateSteinerList();
updateUI();
addLog('手动 Steiner 点',`M${S.manualSpts.length-1} (${Math.round(x)},${Math.round(y)})`);
} else {
S.pts.push([x,y]);
clearRes();updateUI();
addLog('添加终端点',`P${S.pts.length-1} (${Math.round(x)},${Math.round(y)})`);
}
draw();
});

document.getElementById('bclear').addEventListener('click',()=>{
S.pts=[];S.manualSpts=[];clearRes();clearAnim();updateUI();updateSteinerList();
document.getElementById('logbox').innerHTML='<div class="lentry"><div class="lmsg">画布已清空</div></div>';draw();
});
document.getElementById('bundo').addEventListener('click',()=>{
if(S.drawMode==='steiner'&&S.manualSpts.length){
S.manualSpts.pop();updateSteinerList();updateUI();
addLog('撤销','已移除最后一个手动 Steiner 点');draw();
} else if(S.pts.length){
S.pts.pop();clearRes();updateUI();
addLog('撤销','已移除最后一个终端点');draw();
}
});
document.getElementById('bsample').addEventListener('click',()=>{
const w=cvs.width,h=cvs.height,pd=80;
S.pts=[[.18,.28],[.48,.12],[.78,.22],[.12,.58],[.42,.48],[.72,.62],[.28,.78],[.62,.84]]
.map(([rx,ry])=>[pd+rx*(w-2*pd),pd+ry*(h-2*pd)]);
clearRes();clearAnim();updateUI();addLog('示例','已加载 8 个终端点');draw();
});

document.getElementById('kdec').addEventListener('click',()=>{if(S.k>1){S.k--;document.getElementById('kval').textContent=S.k;}});
document.getElementById('kinc').addEventListener('click',()=>{if(S.k<50){S.k++;document.getElementById('kval').textContent=S.k;}});

document.getElementById('brmst').addEventListener('click',()=>{
if(S.pts.length<2){notify('请至少添加 2 个终端点');return;}
const t0=performance.now();
const edges=mst(S.pts),len=edges.reduce((s,e)=>s+e[2],0);
const me=edges.length?Math.max(...edges.map(e=>e[2])):0;
S.rmstEdges=edges.map(e=>[e[0],e[1]]);S.rmstLen=len;
document.getElementById('rrmst').classList.add('active');
document.getElementById('rrmstv').textContent=Math.round(len);
document.getElementById('rrmsts').textContent=`${edges.length} 条边，最长边 ${Math.round(me)}`;
document.getElementById('nohint').style.display='none';
document.getElementById('srmst').textContent=Math.round(len);
setMode('rmst');updateCmp();draw();
addLog('RMST',`总长 ${Math.round(len)}，耗时 ${(performance.now()-t0).toFixed(1)}ms`);
notify(`RMST · 总长 ${Math.round(len)}`);
});

document.getElementById('bapprox').addEventListener('click',()=>{
if(S.pts.length<2){notify('请至少添加 2 个终端点');return;}
clearAnim();
const t0=performance.now(),r=approx2(S.pts,S.k);
S.approxEI=r.ei;S.approxSpts=r.spts;S.approxMax=r.maxE;S.approxLen=r.len;
document.getElementById('rapprox').classList.add('active');
document.getElementById('rapproxv').textContent=Math.round(r.maxE);
document.getElementById('rapproxs').textContent=`最长边 | 总长 ${Math.round(r.len)} | k=${S.k}`;
document.getElementById('nohint').style.display='none';
document.getElementById('smaxe').textContent=Math.round(r.maxE);
setMode('approx');updateCmp();
addLog(`2-近似 (k=${S.k})`,`最长边 ${Math.round(r.maxE)}，总长 ${Math.round(r.len)}，耗时 ${(performance.now()-t0).toFixed(1)}ms`);
S.arunning=true;startAnim(r.steps);
});

// ── Draw mode toggle ──────────────────────────────────────────────────────
const hints={terminal:'点击画布添加终端点',steiner:'点击画布手动放置 Steiner 点'};
document.getElementById('mode-terminal').addEventListener('click',()=>{
S.drawMode='terminal';
document.getElementById('mode-terminal').classList.add('active');
document.getElementById('mode-steiner').classList.remove('active');
document.getElementById('mode-hint').textContent=hints.terminal;
cvs.classList.remove('cursor-steiner');
});
document.getElementById('mode-steiner').addEventListener('click',()=>{
S.drawMode='steiner';
document.getElementById('mode-steiner').classList.add('active');
document.getElementById('mode-terminal').classList.remove('active');
document.getElementById('mode-hint').textContent=hints.steiner;
cvs.classList.add('cursor-steiner');
});
document.querySelectorAll('#vtgls .tbtn').forEach(btn=>{
btn.addEventListener('click',()=>{
const k=btn.dataset.key;S[k]=!S[k];btn.classList.toggle('active',S[k]);draw();
});
});

// ==================== UI ====================
function clearRes(){
S.rmstEdges=null;
S.approxEI=null;S.approxSpts=[];S.rmstLen=null;
['rrmst','rapprox'].forEach(id=>document.getElementById(id).classList.remove('active'));
document.getElementById('nohint').style.display='';
document.getElementById('srmst').textContent='—';
document.getElementById('smaxe').textContent='—';document.getElementById('sopt').textContent='—';
setMode('none');updateCmp();
updateSteinerList(); // clear coords panel too
}

// ── Steiner point coordinate list ─────────────────────────────────────────
// Merges 2-approx and manual Steiner points into a unified scrollable list.
function updateSteinerList(){
const sec=document.getElementById('spt-sec');
const list=document.getElementById('spt-list');
const badge=document.getElementById('spt-badge');

const entries=[];
// Algorithm-generated: 2-approx
S.approxSpts.forEach((p,i)=>entries.push({p,src:'近似',cls:'approx-id',label:`A${i}`,manual:false}));
// Manually placed
S.manualSpts.forEach((p,i)=>entries.push({p,src:'手动',cls:'manual-id',label:`M${i}`,manual:true,idx:i}));

// Always show panel if any manual pts exist
if(!entries.length&&!S.manualSpts.length){sec.style.display='none';return;}
sec.style.display='';
badge.textContent=`${entries.length} 个点`;

list.innerHTML=entries.map(({p,src,cls,label,manual,idx})=>     `<div class="spt-row${manual?' manual deletable':''}"          ${manual?`onclick="removeManualSteiner(${idx})" title="点击删除"`:''}          style="cursor:${manual?'pointer':'default'}">       <span class="spt-id ${cls}">${label}</span>       <span class="spt-coords">(${Math.round(p[0])}, ${Math.round(p[1])})</span>       <span class="spt-src">${src}${manual?' ✕':''}</span>     </div>`).join('');
}

function removeManualSteiner(i){
S.manualSpts.splice(i,1);
updateSteinerList();updateUI();
addLog('删除','已移除手动 Steiner 点 M'+i);draw();
}

// Copy all Steiner coordinates as plain text
document.getElementById('btn-copy-spts').addEventListener('click',()=>{
const entries=[];
S.approxSpts.forEach((p,i)=>entries.push(`近似 A${i}\\t(${Math.round(p[0])}, ${Math.round(p[1])})`));
S.manualSpts.forEach((p,i)=>entries.push(`手动 M${i}\\t(${Math.round(p[0])}, ${Math.round(p[1])})`));
if(!entries.length){notify('暂无 Steiner 点坐标');return;}
const text=entries.join('\n');
navigator.clipboard.writeText(text).then(()=>{
const btn=document.getElementById('btn-copy-spts');
btn.textContent='已复制';btn.style.color='var(--approx-col)';btn.style.borderColor='var(--approx-col)';
setTimeout(()=>{btn.textContent='复制';btn.style.color='';btn.style.borderColor='';},1600);
}).catch(()=>{
// fallback
const ta=document.createElement('textarea');ta.value=text;
document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);
notify('坐标已复制到剪贴板');
});
});
function clearAnim(){
clearTimeout(S.atimer);S.arunning=false;S.apaused=false;S.aidx=0;
S.aei=[];S.aspts=[];S.ahigh=null;
document.getElementById('apbar').style.width='0%';
document.getElementById('sinfo').textContent='等待执行 2-近似算法…';
document.getElementById('apause').textContent='⏸ 暂停';setAnimBtns(false);
}
function updateUI(){
const n=S.pts.length;
document.getElementById('sterm').textContent=n;
document.getElementById('sstein').textContent=S.approxSpts.length+S.manualSpts.length;
document.getElementById('hpts').textContent=`${n} pts`;
const list=document.getElementById('ptlist');
if(!n){list.innerHTML='<div style="font-size:10px;color:var(--muted)">（空）</div>';}
else list.innerHTML=S.pts.map((p,i)=>`<span class="pchip" onclick="removePoint(${i})" title="点击删除">P${i} <span style="color:var(--muted)">(${Math.round(p[0])},${Math.round(p[1])})</span></span>`).join('');
updateSteinerList();
}
function removePoint(i){
S.pts.splice(i,1);clearRes();clearAnim();updateUI();addLog('删除',`已移除 P${i}`);draw();
}
function setMode(m){
const el=document.getElementById('hmode');
el.className='mbadge m-'+m;
el.textContent={none:'待计算',rmst:'RMST',approx:'2-近似'}[m]||m;
}
}
function updateCmp(){
const tbody=document.getElementById('ctbody');
function mme(edges,pts){return edges&&edges.length?Math.round(Math.max(...edges.map(([u,v])=>md(pts[u],pts[v])))):null;}
const rmstMe=S.rmstEdges?mme(S.rmstEdges,S.pts):null;
function row(label,col,len,me,base){
const ls=len!=null?`<span class="${!base&&S.rmstLen&&len<S.rmstLen?'cbest':'cv'}">${Math.round(len)}</span>`:'<span style="color:var(--muted)">—</span>';
const ms=me!=null?`<span class="cv">${me}</span>`:'<span style="color:var(--muted)">—</span>';
const diff=(!base&&S.rmstLen&&len)?`<span class="cdiff">-${((S.rmstLen-len)/S.rmstLen*100).toFixed(1)}%</span>`:'<span style="color:var(--muted)">—</span>';
return `<tr><td style="color:${col}">${label}</td><td>${ls}</td><td>${ms}</td><td>${diff}</td></tr>`;
}
tbody.innerHTML=    `${row('RMST','var(--rmst-col)',S.rmstLen,rmstMe,true)}     ${row('2-近似','var(--approx-col)',S.approxLen,S.approxMax?Math.round(S.approxMax):null,false)}`  ;
}
function addLog(label,val){
const c=document.getElementById('logbox'),e=document.createElement('div');
e.className='lentry';
const now=new Date();
e.innerHTML=`<div class="ltime">${now.toTimeString().slice(0,8)}</div><div class="lmsg">${label} <span class="lval">${val}</span></div>`;
c.insertBefore(e,c.firstChild);if(c.children.length>40)c.removeChild(c.lastChild);
}
function notify(msg){
const el=document.getElementById('nfy');el.textContent=msg;el.classList.add('show');
clearTimeout(el._t);el._t=setTimeout(()=>el.classList.remove('show'),2500);
}

