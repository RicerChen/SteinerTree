// ==================== Canvas → SVG Download ====================
// Reconstructs every visible layer from current state as clean SVG vectors.
// The output is infinitely scalable and compatible with Illustrator / Figma / Inkscape.
function downloadCanvasSVG(){
if(!S.pts.length){notify('请先添加终端点');return;}

const W=parseInt(cvs.style.width)||cvs.width;
const H=parseInt(cvs.style.height)||cvs.height;
const ts=new Date();
const now=ts.toISOString().slice(0,19).replace('T',' ');
// Filename: steiner_YYYYMMDD_HHMMSS.svg
const fname=`steiner_${ts.toISOString().slice(0,10).replace(/-/g,'')}_${ts.toTimeString().slice(0,8).replace(/:/g,'')}.svg`;

// Colours — exact mirror of the C palette used in draw()
const COL={
bg:'#f5f2ec',
grid:'rgba(180,168,155,0.30)',
rmst:'rgba(138,155,176,0.85)',
approx:'rgba(46,158,94,0.85)',
steiner:'#7c4db8',
steinerRing:'rgba(124,77,184,0.28)',
terminal:'#c96a2e',
termRing:'rgba(201,106,46,0.22)',
label:'rgba(201,106,46,0.92)',
labelSub:'rgba(201,106,46,0.48)',
dimText:'#b0a49a',
animHL:'#c96a2e',
};

// Round to 2 decimal places for compact output
const r=v=>Math.round(v*100)/100;

// L-shaped rectilinear path: horizontal then vertical
function lpath(p1,p2){
if(!p1||!p2)return '';
return `M${r(p1[0])},${r(p1[1])} H${r(p2[0])} V${r(p2[1])}`;
}

const parts=[];

// ── <defs>: Google Fonts import so text renders correctly everywhere ──
parts.push(`<defs>   <style>@import url('<https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&amp;display=swap>');</style> </defs>`);

// ── Background ───────────────────────────────────────────────────────
parts.push(`<rect width="${W}" height="${H}" fill="${COL.bg}"/>`);

// ── Dot grid (using <pattern> for compact SVG) ───────────────────────
parts.push(`<defs>   <pattern id="dotgrid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">     <circle cx="40" cy="40" r="0.8" fill="${COL.grid}"/>   </pattern> </defs> <rect width="${W}" height="${H}" fill="url(#dotgrid)"/>`);

// ── RMST edges ───────────────────────────────────────────────────────
if(S.showRmst&&S.rmstEdges&&S.rmstEdges.length){
const paths=S.rmstEdges.map(([u,v])=>
`<path d="${lpath(S.pts[u],S.pts[v])}" stroke="${COL.rmst}" stroke-width="1.5" stroke-dasharray="5 4" fill="none"/>`
).filter(Boolean);
parts.push(`<g id="rmst" opacity="1">\\n  ${paths.join('\\n  ')}\\n</g>`);
}

// ── 2-Approx final result ────────────────────────────────────────────
const showFinalApprox=S.showApprox&&S.approxEI&&!S.arunning&&S.aidx===0;
if(showFinalApprox){
const paths=S.approxEI.map(e=>
`<path d="${lpath(e.p1,e.p2)}" stroke="${COL.approx}" stroke-width="2.5" fill="none"/>`
).filter(Boolean);
const spts=S.approxSpts.map(sp=>
`<circle cx="${r(sp[0])}" cy="${r(sp[1])}" r="4" fill="${COL.steiner}"/>`
);
parts.push(`<g id="approx">\\n  ${paths.join('\\n  ')}\\n</g>`);
if(spts.length) parts.push(`<g id="approx-steiner">\\n  ${spts.join('\\n  ')}\\n</g>`);
}

// ── Animation layer snapshot (captures current mid-anim frame) ───────
const showAnimSnap=S.showAnim&&(S.arunning||S.aidx>0)&&S.aei.length;
if(showAnimSnap){
const paths=S.aei.map(e=>{
const isH=S.ahigh&&e.u===S.ahigh.u&&e.v===S.ahigh.v;
return `<path d="${lpath(e.p1,e.p2)}" stroke="${isH?COL.animHL:COL.approx}" stroke-width="${isH?3:2}" fill="none"/>`;
}).filter(Boolean);
const spts=S.aspts.map(sp=>
`<circle cx="${r(sp[0])}" cy="${r(sp[1])}" r="4" fill="${COL.steiner}"/>`
);
const hlPts=[];
if(S.ahigh){
const e=S.ahigh;
const[x1,y1]=e.p1,[x2,y2]=e.p2,cnt=e.sc+1;
for(let j=1;j<cnt;j++){
const t=j/cnt,sx=r(x1+(x2-x1)*t),sy=r(y1+(y2-y1)*t);
hlPts.push(`<circle cx="${sx}" cy="${sy}" r="20" fill="${COL.termRing}"/>`);
hlPts.push(`<circle cx="${sx}" cy="${sy}" r="9"  fill="${COL.termRing}"/>`);
hlPts.push(`<circle cx="${sx}" cy="${sy}" r="5"  fill="${COL.animHL}"/>`);
}
}
parts.push(`<g id="anim-layer">\\n  ${[...paths,...hlPts,...spts].join('\\n  ')}\\n</g>`);
}

// ── Terminal points ──────────────────────────────────────────────────
const termEls=S.pts.map((p,i)=>{
const x=r(p[0]),y=r(p[1]);
const labelEls=S.showLabels?   `<text x="${x}" y="${y-16}" text-anchor="middle"         font-family="'JetBrains Mono',monospace" font-size="10" font-weight="600"         fill="${COL.label}">P${i}</text>   <text x="${x}" y="${y+21}" text-anchor="middle"         font-family="'JetBrains Mono',monospace" font-size="8.5"         fill="${COL.labelSub}">(${Math.round(p[0])},${Math.round(p[1])})</text>`:'';
return `\\   <!-- terminal P${i} -->   <circle cx="${x}" cy="${y}" r="16" fill="${COL.termRing}"/>   <circle cx="${x}" cy="${y}" r="9"  fill="none" stroke="${COL.terminal}" stroke-width="1.5" opacity="0.5"/>   <circle cx="${x}" cy="${y}" r="5.5" fill="${COL.terminal}"/>   ${labelEls}`;
});
parts.push(`<g id="terminals">\\n${termEls.join('\\n')}\\n</g>`);

// ── Legend (bottom-left, always included) ────────────────────────────
const legendItems=[];
if(S.rmstEdges)  legendItems.push({col:COL.rmst,   dash:'5,4',label:'RMST'});
if(S.approxEI)   legendItems.push({col:COL.approx, dash:'',   label:`2-近似 (k=${S.k})`});
if(legendItems.length){
const LX=14,LY=H-14-legendItems.length*18;
const els=legendItems.map((it,i)=>{
const y=LY+i*18;
return `\\   <line x1="${LX}" y1="${y}" x2="${LX+22}" y2="${y}" stroke="${it.col}" stroke-width="2" stroke-dasharray="${it.dash}"/>   <text x="${LX+28}" y="${y+4}" font-family="'JetBrains Mono',monospace" font-size="9" fill="${COL.dimText}">${it.label}</text>`;
});
parts.push(`<g id="legend">\\n${els.join('\\n')}\\n</g>`);
}

// ── Metadata footer ──────────────────────────────────────────────────
parts.push(`<text x="10" y="${H-6}" font-family="'JetBrains Mono',monospace" font-size="7.5" fill="${COL.dimText}">Rectilinear Steiner Tree · n=${S.pts.length} terminals · ${now}</text>`);

// ── Assemble final SVG ───────────────────────────────────────────────
const svg=`<?xml version="1.0" encoding="UTF-8"?> <svg xmlns="<http://www.w3.org/2000/svg>"      width="${W}" height="${H}"      viewBox="0 0 ${W} ${H}"      shape-rendering="geometricPrecision"      text-rendering="optimizeLegibility">   <title>Rectilinear Steiner Tree — n=${S.pts.length}</title>   <desc>Generated ${now} · Iterated 1-Steiner heuristic</desc> ${parts.join('\\n')} </svg>`;

const blob=new Blob([svg],{type:'image/svg+xml;charset=utf-8'});
const a=document.createElement('a');
a.href=URL.createObjectURL(blob);
a.download=fname;
document.body.appendChild(a);
a.click();
document.body.removeChild(a);
setTimeout(()=>URL.revokeObjectURL(a.href),8000);
notify(`矢量图已下载 · ${fname}`);
}

document.getElementById('btn-dl-svg').addEventListener('click', downloadCanvasSVG);

// Init
updateUI();
</script>
