function buildExport(){
const d=exportData();
document.getElementById('ejson').textContent=JSON.stringify(d,null,2);
document.getElementById('ecsv').textContent=toCSV(d);
document.getElementById('epy').textContent=toPy(d);
document.getElementById('esvg').textContent=toSVG(d);
}
function exportData(){
return{
meta:{generated:new Date().toISOString(),canvas:{w:cvs.width,h:cvs.height},description:'Rectilinear Steiner Tree Export'},
terminals:S.pts.map((p,i)=>({id:`P${i}`,x:Math.round(p[0]),y:Math.round(p[1])})),
results:{
rmst:S.rmstLen?{total_length:Math.round(S.rmstLen),max_edge:S.rmstEdges?Math.round(Math.max(...S.rmstEdges.map(([u,v])=>md(S.pts[u],S.pts[v])))):null,edges:S.rmstEdges?S.rmstEdges.map(([u,v])=>({from:`P${u}`,to:`P${v}`,length:Math.round(md(S.pts[u],S.pts[v]))})):[]}:null,
bottleneck_2approx:S.approxLen?{k:S.k,total_length:Math.round(S.approxLen),max_edge_length:Math.round(S.approxMax),steiner_points:S.approxSpts.map((p,i)=>({id:`A${i}`,x:Math.round(p[0]),y:Math.round(p[1])})),edges:S.approxEI?S.approxEI.map(e=>({from:`P${e.u}`,to:`P${e.v}`,original_length:Math.round(e.length),steiner_count:e.sc,max_segment:Math.round([e.cm](http://e.cm/))})):[]}:null,
}
};
}
function toCSV(d){
let s='# Rectilinear Steiner Tree Export\n# Terminals\ntype,id,x,y\n';
for(const t of d.terminals)s+=`terminal,${t.id},${t.x},${t.y}\\n`;
if(d.results.bottleneck_2approx?.steiner_points?.length){s+='\n# 2-Approx Steiner Points\n';for(const p of d.results.bottleneck_2approx.steiner_points)s+=`approx_steiner,${p.id},${p.x},${p.y}\\n`;}
s+='\n# Edges\nalgorithm,from,to,length\n';
if(d.results.rmst?.edges)for(const e of d.results.rmst.edges)s+=`RMST,${e.from},${e.to},${e.length}\\n`;
if(d.results.bottleneck_2approx?.edges)for(const e of d.results.bottleneck_2approx.edges)s+=`2APPROX,${e.from},${e.to},${e.original_length}\\n`;
return s;
}
function toPy(d){
const pts=d.terminals.map(t=>`(${t.x}, ${t.y})`).join(', ');
let s=`# Rectilinear Steiner Tree - Python\\nimport numpy as np\\nimport matplotlib.pyplot as plt\\nimport matplotlib.patches as mpatches\\n\\n`;
s+=`terminals = [${pts}]\\n\\n`;
if(d.results.bottleneck_2approx){const r=d.results.bottleneck_2approx;s+=`approx_k = ${r.k}\\napprox_steiner = [${r.steiner_points.map(p=>`(${p.x},${p.y})`).join(',')||''}]\\napprox_total = ${r.total_length}\\napprox_max_edge = ${r.max_edge_length}\\n\\n`;}
s+=`# Plot\\nfig, ax = plt.subplots(figsize=(9,7))\\ntx=[p[0] for p in terminals]; ty=[p[1] for p in terminals]\\nax.scatter(tx, ty, c='#ff6b35', s=90, zorder=5, label='Terminals')\\nfor i,(x,y) in enumerate(terminals):\\n    ax.annotate(f'P{i}', (x,y), textcoords='offset points', xytext=(5,5), fontsize=9)\\nplt.title('Rectilinear Steiner Tree')\\nplt.legend(); plt.axis('equal'); plt.tight_layout(); plt.show()\\n`;
return s;
}
function toSVG(d){
const W=cvs.width,H=cvs.height;
let s=`<svg xmlns="<http://www.w3.org/2000/svg>" width="${W}" height="${H}" viewBox="0 0 ${W} ${H}">\\n`;
s+=  `<rect width="${W}" height="${H}" fill="#0a0e1a"/>\\n`;
if(d.results.rmst?.edges){
s+=  `<g id="rmst" stroke="#607080" stroke-width="1.5" stroke-dasharray="5,4" fill="none" opacity="0.8">\\n`;
for(const e of d.results.rmst.edges){
const pi=parseInt(e.from.slice(1)),pj=parseInt(e.to.slice(1));
const p1=d.terminals[pi],p2=d.terminals[pj];
s+=    `<polyline points="${p1.x},${p1.y} ${p2.x},${p1.y} ${p2.x},${p2.y}"/>\\n`;
}
s+=  `</g>\\n`;
}
s+=  `<g id="terminals" fill="#ff6b35">\\n`;
for(const t of d.terminals)s+=    `<circle cx="${t.x}" cy="${t.y}" r="5"/>\\n    <text x="${t.x}" y="${t.y-10}" fill="#ff6b35" font-size="10" text-anchor="middle" font-family="monospace">${t.id}</text>\\n`;
s+=  `</g>\\n  <text x="10" y="${H-10}" fill="#334155" font-size="9" font-family="monospace">Generated: ${d.meta.generated}</text>\\n</svg>`;
return s;
}

